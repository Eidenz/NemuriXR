{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NemuriXR",
  "version": "0.1.0",
  "identifier": "com.eidenz.nemurixr",
  "build": {
    "beforeDevCommand": "pnpm stage-overlay:debug && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && pnpm stage-overlay:release",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NemuriXR",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 620,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "externalBin": ["binaries/nemurixr-overlay"],
    "category": "Utility",
    "shortDescription": "VR sleeping utility for Monado",
    "longDescription": "NemuriXR — an in-headset and desktop sleeping utility for VR on Linux/Monado: brightness & fan control, sleep schedule, VRChat join/leave notifications, auto-accept invites + status automations, and OSC.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
